# ============================================================
# DentalFlow — Variables de Entorno
# Copia este archivo como .env y completa los valores
# ============================================================

# ---- Servidor ----
PORT=3000
NODE_ENV=development

# ---- Base de Datos ----
# Ruta al archivo SQLite (relativa a /backend)
DB_PATH=./db/dentalflow.db

# ---- OpenAI ----
# Obtén tu key en: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ---- WhatsApp Cloud API (Meta) ----
# 1. Crea una app en: https://developers.facebook.com
# 2. Agrega el producto "WhatsApp"
# 3. Obtén el token de acceso temporal (o permanente con System User)
WHATSAPP_TOKEN=EAAxxxxxxxxxx
WHATSAPP_PHONE_NUMBER_ID=1234567890
WHATSAPP_VERIFY_TOKEN=dentalflow_webhook_secret_2024

# ---- Configuración del Consultorio ----
CLINIC_NAME=Dr. García Odontología
CLINIC_PHONE=+5491112345678

# ---- Modo Demo ----
# Si está en "true", los mensajes se imprimen en consola sin enviar por WhatsApp
# Útil para desarrollo sin credenciales
DEMO_MODE=true
